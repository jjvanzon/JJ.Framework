<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.253.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Reflection.Legacy" Version="0.253.6073" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.5.6068" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.5.6073" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Reflection.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Reflection.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Reflection.Tests\bin\**" />
    <Compile Include="..\Reflection.TrimTests\Program.cs" />
    <Compile Include="..\Reflection.TrimTests\Untrimmer.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reflection.Core.Tests.Helpers\JJ.Framework.Reflection.Core.Tests.Helpers.csproj" />
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.5.6068" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

</Project>

