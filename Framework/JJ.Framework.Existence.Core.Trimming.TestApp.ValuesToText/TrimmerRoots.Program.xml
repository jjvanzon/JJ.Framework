<?xml version="1.0" encoding="utf-8"?>
<linker>
  <!--
    This descriptor makes a specific Program type/method a trimmer root instead of the
    whole assembly. Replace the type fullname below with the exact namespace-qualified
    name of the Program class in this project (for example: "My.Namespace.Program").

    Example to keep the Main method only:
      <assembly fullname="JJ.Framework.Existence.Core.Trimming.TestApp.ValuesToText">
        <type fullname="My.Namespace.Program" preserve="all">
          <method name="Main"/>
        </type>
      </assembly>

    If you want to preserve the entire Program type, use preserve="all" as shown.
  -->

  <assembly fullname="JJ.Framework.Existence.Core.Trimming.TestApp.ValuesToText">
    <!-- The compiler places the generated Program type into the project's
         root namespace by default. Use the namespace-qualified name so the
         linker can find the generated type and its Main entrypoint. -->
    <type fullname="JJ.Framework.Existence.Core.Trimming.TestApp.ValuesToText.Program" preserve="all">
      <method name="Main" />
    </type>
  </assembly>
</linker>
