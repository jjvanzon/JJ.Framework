<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>3.7.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Business.Core" Version="3.7.4847" />
    <PackageReference Include="JJ.Framework.Business.Legacy" Version="0.250.4995" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="3.8.4995" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Build\JJ.Framework.Build.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Business.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Business.Core.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Business.Core.Tests\bin\**" />
  </ItemGroup>

  <Import Project="..\JJ.Framework.PlatformCompatibility.Core\JJ.Framework.PlatformCompatibility.Core.projitems" Label="Shared" />
  <Import Project="..\JJ.Framework.SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootAssembly Include="$(AssemblyName)" />
  </ItemGroup>

</Project>
