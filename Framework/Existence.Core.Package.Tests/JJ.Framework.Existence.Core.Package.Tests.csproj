<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net461</TargetFrameworks>
    <Version>4.6.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="4.5.6194" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.5.6194" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.253.6194" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.5.6194" />

  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Existence.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Existence.Core.Tests\obj\**" />
    <Compile Remove="..\Existence.Core.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

