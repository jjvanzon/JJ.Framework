<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net5.0;net461</TargetFrameworks>
    <Version>4.6.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Configuration.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Configuration.Core.Tests\obj\**" />
    <Compile Remove="..\Configuration.Core.Tests\bin\**" />
    <None Include="..\Configuration.Core.Tests\**\*.config" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <None Remove="..\Configuration.Core.Tests\obj\**\*.config" />
    <None Remove="..\Configuration.Core.Tests\bin\**\*.config" />
  </ItemGroup>

 <ItemGroup>
    <EmbeddedResource Include="..\Configuration.Core.Tests.Dummy\*.cs" Link="TestResources\%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Configuration.Core.Tests.Dummy\*.config" Link="TestResources\%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Configuration.Core\build\JJ.Framework.Configuration.Core.targets" Link="TestResources\%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Configuration.Core.Package.Tests.Dummy\JJ.Framework.Configuration.Core.Package.Tests.Dummy.csproj" Link="TestResources\JJ.Framework.Configuration.Core.Tests.Dummy.csproj" />
    <None Remove="..\Configuration.Core.Tests\app.config" />
  </ItemGroup>
  
  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="4.6.6335" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.3" />
    <PackageReference Include="JJ.Framework.Configuration.Core" Version="4.6.6323" />
    <PackageReference Include="JJ.Framework.Configuration.Legacy" Version="0.254.6323" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.6.6289" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.6.6282" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>