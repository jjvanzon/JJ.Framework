<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks> <!-- NCrunch wide range for Package.Tests -->
    <Version>5.2.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="5.1.7246-preview" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7388" />
    <PackageReference Include="JJ.Framework.Reflection.Core" Version="5.1.7388" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7388" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>