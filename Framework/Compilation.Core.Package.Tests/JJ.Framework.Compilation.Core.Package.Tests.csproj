<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Not sure why NCrunch refuses net48 and net462. -->
    <!--<TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks>-->
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net462;net461</TargetFrameworks>
    <Version>5.1.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="5.1.7246-preview" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7246" />
    <PackageReference Include="JJ.Framework.Reflection.Core" Version="5.1.7246" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7246" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>