<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>5.1.0</Version>
    <OutputType>Exe</OutputType>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
    <Compile Include="..\Compilation.Core.TrimTests\Program.cs" />
    <Compile Include="..\Compilation.Core.TrimTests\Untrimmer.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="5.1.7246-preview" />
    <PackageReference Include="JJ.Framework.Reflection.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7347" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
    <TrimmerRootAssembly Include="JJ.Framework.Compilation.Core.Package.TrimTests" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>

