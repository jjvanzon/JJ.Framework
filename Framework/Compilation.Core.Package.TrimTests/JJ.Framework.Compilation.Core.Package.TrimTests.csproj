<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.7.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <AutoTrimTest Condition="$(IsNCrunch)">False</AutoTrimTest>
    <AutoTrimTest Condition="$(IsAzurePipelines)">True</AutoTrimTest>
    <!--<AutoTrimTest>True</AutoTrimTest>-->
    <!--<AutoTrimTest>False</AutoTrimTest>-->
    <!--<AutoPublish>True</AutoPublish>-->
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
    <Compile Include="..\Compilation.Core.TrimTests\Program.cs" />
    <Compile Include="..\Compilation.Core.TrimTests\Untrimmer.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="4.6.6993" />
    <PackageReference Include="JJ.Framework.Reflection.Core" Version="4.6.6993" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.6.6993" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.6.6993" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.6.6993" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
    <TrimmerRootAssembly Include="JJ.Framework.Compilation.Core.Package.TrimTests" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>

