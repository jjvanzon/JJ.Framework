<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>5.1.$(BuildNum)</Version>
    <OutputType>Exe</OutputType>
    <!-- TargetFramework is also used for compilations fired off at run-time and those need a stretch of .NET versions for coverage. -->
    <!--<TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks>-->
    <!-- But Trimming only can apply to .NET 5 and onward (we exclude .NET 5 for reasons here. See TargetFrameworks.xml -->
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
    <Compile Include="..\Compilation.Core.TrimTests\Program.cs" />
    <Compile Include="..\Compilation.Core.TrimTests\Untrimmer.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Compilation.Core" Version="5.1.7246-preview" />
    <PackageReference Include="JJ.Framework.Reflection.Core" Version="5.1.7246" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7246" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7246" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7246" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
    <TrimmerRootAssembly Include="JJ.Framework.Compilation.Core.Package.TrimTests" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>

