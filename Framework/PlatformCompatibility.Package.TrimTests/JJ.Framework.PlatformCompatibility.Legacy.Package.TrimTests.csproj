<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.254.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.IO.Core" Version="4.6.6282" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Legacy" Version="0.254.6282" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.6.6282" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.254.6282" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.6.6282" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.PlatformCompatibility.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.PlatformCompatibility.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.PlatformCompatibility.Tests\bin\**" />
    <Compile Include="..\PlatformCompatibility.TrimTests\Program.cs" />
  </ItemGroup>
      
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.6.6282" />
  </ItemGroup>
</Project>

