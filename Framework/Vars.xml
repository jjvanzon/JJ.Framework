<Project>
  <PropertyGroup>
    <IsCore>$(MSBuildProjectName.Contains('Core'))</IsCore>
    <IsLegacy>$(MSBuildProjectName.Contains('Legacy'))</IsLegacy>
    <IsNet48>$(MSBuildProjectName.Contains('Net48'))</IsNet48>
    <IsTest>False</IsTest>
    <IsTest Condition="$(MSBuildProjectName.EndsWith('.Tests'))">True</IsTest>
    <IsTest Condition="$(MSBuildProjectName.Contains('.Tests.'))">True</IsTest>
    <IsTest Condition="$(MSBuildProjectName.EndsWith('.TestBase'))">True</IsTest>
    <IsTest Condition="$(MSBuildProjectName.Contains('.TestBase.'))">True</IsTest>
    <IsTrimTest>$(MSBuildProjectName.Contains('TrimTests'))</IsTrimTest>
    <IsNet5>$(TargetFramework.Equals('net5.0'))</IsNet5>
    <IsNet6>$(TargetFramework.Equals('net6.0'))</IsNet6>
    <IsNet7>$(TargetFramework.Equals('net7.0'))</IsNet7>
    <IsNet8>$(TargetFramework.Equals('net8.0'))</IsNet8>
    <IsNet9>$(TargetFramework.Equals('net9.0'))</IsNet9>
    <IsNet10>$(TargetFramework.Equals('net10.0'))</IsNet10>
    <IsOuterBuild>True</IsOuterBuild>
    <IsOuterBuild Condition="'$(TargetFramework)'!=''">False</IsOuterBuild>
    <IsInnerBuild>False</IsInnerBuild>
    <IsInnerBuild Condition="'$(TargetFramework)'!=''">True</IsInnerBuild>
    <!-- Turn IsNCrunch String into a proper Boolean-->
    <IsNCrunch Condition="'$(IsNCrunch)'!='True'">False</IsNCrunch>
    <IsNCrunch Condition="'$(IsNCrunch)'=='True'">True</IsNCrunch>
    <IsAzurePipelines>False</IsAzurePipelines>
    <IsAzurePipelines Condition="'$(TF_BUILD)'=='true'">True</IsAzurePipelines>
    <AutoPublish>False</AutoPublish>
    <AutoPublish Condition="$(IsTrimTest) And $(IsInnerBuild) And '$(Configuration)'=='Release'">True</AutoPublish>
    <AutoTrimTest>False</AutoTrimTest>
    <AutoTrimTest Condition="$(IsTrimTest) And $(IsInnerBuild) And ('$(Configuration)'=='Release' Or $(IsNCrunch))">True</AutoTrimTest>
    <SolutionDirjj>$(SolutionDir)</SolutionDirjj>
    <SolutionDirjj Condition="'$(SolutionDirjj)'==''">$(MSBuildThisFileDirectory)\..\</SolutionDirjj>
  </PropertyGroup>

  <!-- Diagnostics -->
  <Target Name="JJ_Framework_Vars_BuildType" BeforeTargets="Build">
    <Message Text="$(MSBuildProjectName) > IsCore = $(IsCore) | IsLegacy = $(IsLegacy) | IsNet48 = $(IsNet48) | IsTest = $(IsTest) | IsTrimTest = $(IsTrimTest)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > IsOuterBuild = $(IsOuterBuild) | IsInnerBuild = $(IsInnerBuild) | IsNCrunch = $(IsNCrunch)  | IsAzurePipelines = $(IsAzurePipelines) | AutoTrimTest = $(AutoTrimTest)" Importance="High" />
    <Message Condition="'$(IsInnerBuild)'=='True'" Text="$(MSBuildProjectName) > IsNet5 = $(IsNet5) | IsNet6 = $(IsNet6) | IsNet7 = $(IsNet7) | IsNet8 = $(IsNet8) | IsNet9 = $(IsNet9) | IsNet10 = $(IsNet10)" Importance="High" />
  </Target>
</Project>
