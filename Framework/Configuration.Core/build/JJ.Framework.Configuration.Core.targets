<!--
  Automatically copies app.config to the output directory under the names that
  System.Configuration.ConfigurationManager and common test hosts expect,
  so consuming projects get legacy System.Configuration support with zero effort.

  Only runs for non-.NET-Framework TFMs (SDK-style projects targeting net5.0+,
  netstandard*, etc.) where the SDK does NOT auto-copy app.config.
  Skipped entirely when no app.config is present in the project directory.
-->
<Project>
  <Target Name="JJ_CopyAppConfigForLegacySystemConfiguration"
          AfterTargets="Build"
          Condition="'$(TargetFrameworkIdentifier)' != '.NETFramework'
                     And Exists('$(MSBuildProjectDirectory)\app.config')">

    <PropertyGroup>
      <SourceConfig>$(MSBuildProjectDirectory)\app.config</SourceConfig>
      <!-- Config with assembly name, e.g. MyApp.dll.config -->
      <AssemblyNameConfig>$(TargetDir)$(TargetFileName).config</AssemblyNameConfig>
      <!-- For MSTest / VSTest / dotnet test -->
      <TestHostConfig>$(TargetDir)testhost.dll.config</TestHostConfig>
      <!-- For nCrunch -->
      <NCrunchConfig>$(TargetDir)nCrunch.TaskRunner.DotNetCore.20.x64.dll.config</NCrunchConfig>
    </PropertyGroup>

    <Message Text="Copy '$(SourceConfig)' -> '$(AssemblyNameConfig)'" Importance="High" />

    <Copy SourceFiles="$(SourceConfig)"
          DestinationFiles="$(AssemblyNameConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

    <Message Text="Copy '$(SourceConfig)' -> '$(TestHostConfig)'" Importance="High" />

    <Copy SourceFiles="$(SourceConfig)"
          DestinationFiles="$(TestHostConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

    <Message Text="Copy '$(SourceConfig)' -> '$(NCrunchConfig)'" Importance="High" />

    <Copy SourceFiles="$(SourceConfig)"
          DestinationFiles="$(NCrunchConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

  </Target>
</Project>
