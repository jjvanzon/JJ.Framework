<!--
  Automatically copies app.config to the output directory under the names that
  System.Configuration.ConfigurationManager and common test hosts expect,
  so consuming projects get legacy System.Configuration support with zero effort.
-->

<Project TreatAsLocalProperty="AppConfig;AppConfigExists;AssemblyNameConfig;TestHostConfig;NCrunchConfig">
  <Target Name="JJ_CopyConfig" AfterTargets="Build" Condition="'$(TargetFileName)'!=''">

    <PropertyGroup>
      <AppConfig>$(MSBuildProjectDirectory)\app.config</AppConfig>
      <AppConfigExists>False</AppConfigExists>
      <AppConfigExists Condition="Exists('$(MSBuildProjectDirectory)\app.config')">True</AppConfigExists>
      <AssemblyNameConfig>$(TargetDir)$(TargetFileName).config</AssemblyNameConfig> <!-- Config with assembly name, e.g. MyApp.dll.config -->
      <TestHostConfig>$(TargetDir)testhost.dll.config</TestHostConfig> <!-- For MSTest / VSTest / dotnet test -->
      <NCrunchConfig>$(TargetDir)nCrunch.TaskRunner.DotNetCore.20.x64.dll.config</NCrunchConfig>
    </PropertyGroup>

    <Message Condition="!$(AppConfigExists)" Text="$(MSBuildProjectName) > No app.config to copy ($(AppConfig))" Importance="High" />
    
    <Message Condition="$(AppConfigExists)" Text="$(MSBuildProjectName) > Copy '$(AppConfig)' -> '$(AssemblyNameConfig)'" Importance="High" />

    <Copy Condition="$(AppConfigExists)"
          SourceFiles="$(AppConfig)"
          DestinationFiles="$(AssemblyNameConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

    <Message Condition="$(AppConfigExists)" Text="$(MSBuildProjectName) > Copy '$(AppConfig)' -> '$(TestHostConfig)'" Importance="High" />

    <Copy Condition="$(AppConfigExists)"
          SourceFiles="$(AppConfig)"
          DestinationFiles="$(TestHostConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

    <Message Condition="$(AppConfigExists)" Text="$(MSBuildProjectName) > Copy '$(AppConfig)' -> '$(NCrunchConfig)'" Importance="High" />

    <Copy Condition="$(AppConfigExists)"
          SourceFiles="$(AppConfig)"
          DestinationFiles="$(NCrunchConfig)"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true" />

  </Target>
</Project>
