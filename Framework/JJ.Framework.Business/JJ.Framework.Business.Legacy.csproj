<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.257.$(BuildNum)</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;netstandard2.1;netstandard2.0</TargetFrameworks>
    <Description>Helpers for business logic. Result types for returning both Data and (error) information. Use ISideEffect to separate business logic units. EntityStatusManager is a container for dirty/new/deleted flags and there is a check if a list is dirty.</Description>
    <PackageTags>result types messages success flag successful entity state side effect check dirty deleted new entitystatusmanager entitystatusmanagerbyid listisdirty isideeffect getlistisdirty</PackageTags>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.Business</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.Business</PackageProjectUrl>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup>
    <WarningsAsErrors>$(WarningsAsErrors);Nullable</WarningsAsErrors>
    <WarningsAsErrors>$(WarningsAsErrors);CA1062</WarningsAsErrors><!-- API surface nulls -->
  </PropertyGroup>

  <PropertyGroup Condition="$(IsNet8) Or $(IsNet9) Or $(IsNet10)">
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="$(IsNet6) Or $(IsNet7)">
    <IsTrimmable>True</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.PlatformCompatibility\JJ.Framework.PlatformCompatibility.Legacy.csproj" />
    <ProjectReference Include="..\JJ.Framework.Reflection\JJ.Framework.Reflection.Legacy.csproj" />
  </ItemGroup>

  <Import Project="..\PlatformCompatibility.Core.SharedProject\JJ.Framework.PlatformCompatibility.Core.SharedProject.projitems" Label="Shared" />
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>
