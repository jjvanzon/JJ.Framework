<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>3.9.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="3.9.5203" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="3.9.5197" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.250.5197" />
  </ItemGroup>

  <ItemGroup>
    
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Existence.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Existence.Core.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Existence.Core.Tests\bin\**" />
    <Compile Include="..\JJ.Framework.Existence.Core.Trimming.TestApp\Program.cs" />
    <!-- Exclude tests that rely heavily on reflection or APIs not compatible with trimming analysis -->
    <Compile Remove="..\JJ.Framework.Existence.Core.Tests\Existence_CrossRefCollectionTypes_Tests.cs" />
  </ItemGroup>

  <Import Project="..\JJ.Framework.PlatformCompatibility.Core\JJ.Framework.PlatformCompatibility.Core.projitems" Label="Shared" />
  <Import Project="..\JJ.Framework.SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootAssembly Include="$(AssemblyName)" />
  </ItemGroup>

</Project>
