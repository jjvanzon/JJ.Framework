<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks> <!-- NCrunch wide range for Package.Tests -->
    <Version>0.259.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Text.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Text.Core.Tests\obj\**" />
    <Compile Remove="..\Text.Core.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Text.Core" Version="5.1.7388" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7388" />
    <PackageReference Include="MSTest" Version="3.7.3" />
  </ItemGroup>
</Project>

