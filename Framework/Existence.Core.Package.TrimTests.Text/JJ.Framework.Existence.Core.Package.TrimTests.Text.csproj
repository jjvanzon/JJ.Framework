<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>5.1.0</Version>
    <OutputType>Exe</OutputType>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.259.7347" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7347" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Existence.Core.Tests.Text\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Existence.Core.Tests.Text\obj\**" />
    <Compile Remove="..\Existence.Core.Tests.Text\bin\**" />
    <Compile Include="..\Existence.Core.TrimTests.Text\Program.cs" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7347" />
  </ItemGroup>
</Project>

