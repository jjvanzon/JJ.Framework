<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net461</TargetFrameworks>
    <Version>0.259.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Validation.Legacy.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Validation.Legacy.Tests\obj\**" />
    <Compile Remove="..\Validation.Legacy.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.259.7246" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7246" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7246" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Validation.Legacy.Package.Tests.Helpers\JJ.Framework.Validation.Legacy.Package.Tests.Helpers.csproj" />
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
      
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>

