<Project>
  <PropertyGroup Condition="'$(OutputType)'=='Exe' And $(IsInnerBuild)">
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish)">
    <!--<RuntimeIdentifier>win-x64</RuntimeIdentifier>-->
    <SelfContained>True</SelfContained>
    <PublishReadyToRun>True</PublishReadyToRun>
  </PropertyGroup>
  
  
  <!--<PropertyGroup Condition="$(AutoPublish) And $(IsInnerBuild)">
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>True</SelfContained>
    <PublishReadyToRun>True</PublishReadyToRun>
  </PropertyGroup>-->
  
  
  <PropertyGroup Condition="$(AutoPublish) And ($(IsNet9) Or $(IsNet10))">
    <PublishTrimmed>True</PublishTrimmed>
    <PublishAot>True</PublishAot>
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish) And $(IsNet8)">
    <PublishTrimmed>True</PublishTrimmed>
    <PublishAot>True</PublishAot>
    <!--<PublishSingleFile>True</PublishSingleFile>-->
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish) And ($(IsNet6) Or $(IsNet7))">
    <PublishTrimmed>True</PublishTrimmed>
    <!--<PublishAot>True</PublishAot>-->
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish) And $(IsNet5)">
    <!--<PublishTrimmed>True</PublishTrimmed>-->
    <!--<PublishAot>True</PublishAot>-->
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish) And '$(Configuration)'=='Release'">
    <CopyOutputSymbolsToPublishDirectory>False</CopyOutputSymbolsToPublishDirectory>
  </PropertyGroup>

  <PropertyGroup Condition="$(AutoPublish) And $(IsInnerBuild)">
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <!--<PublishDir>publish\$(Configuration)\$(TargetFramework)</PublishDir>-->
    <PublishDir>$(MSBuildProjectDirectory)\publish\$(Configuration)\$(TargetFramework)</PublishDir>
  </PropertyGroup>

  <Target Name="PublishAfterBuild" AfterTargets="Build" Condition="$(AutoPublish) And $(IsInnerBuild)">
    <MSBuild Condition="!$(IsNCrunch)" Targets="Publish" 
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true" />

    <MSBuild Condition="$(IsNCrunch) And ($(IsNet9) Or $(IsNet10))" Targets="Publish"
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishTrimmed=true;PublishAot=true;PublishSingleFile=true;PublishReadyToRun=true" />

    <MSBuild Condition="$(IsNCrunch) And $(IsNet8)" Targets="Publish"
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishTrimmed=true;PublishAot=true;PublishReadyToRun=true" />
  </Target>
  
  <Target Name="RemoveSymbolsAndDocs" AfterTargets="Publish" Condition="$(AutoPublish) And $(IsInnerBuild) And '$(PublishDir)'!=''">
    <Message Importance="High" Text="Removing symbols and docs from publish directory..." />
    <Message Importance="High" Text="PublishDir = $(PublishDir)" />

    <ItemGroup><PdbsToDeletejj Include="$(PublishDir)*.pdb" /></ItemGroup>
    <Message Importance="High" Text="Removing $(PublishDir)*.pdb" />
    <Message Importance="High" Text="Removing @(PdbsToDeletejj)" />
    <Delete Files="@(PdbsToDeletejj)" />

    <ItemGroup><XmlsToDeletejj Include="$(PublishDir)*.xml" /></ItemGroup>
    <Message Importance="High" Text="Removing $(PublishDir)*.xml" />
    <Message Importance="High" Text="Removing @(XmlsToDeletejj)" />
    <Delete Files="@(XmlsToDeletejj)" />
  </Target>

  <!-- Diagnostics (Publish) -->
  <Target Name="JJ_Framework_Vars_Publish" AfterTargets="Build" Condition="$(AutoPublish) And $(IsInnerBuild)">
    <Message Text="$(MSBuildProjectName) > SelfContained = $(SelfContained) | PublishTrimmed = $(PublishTrimmed) | PublishAot = $(PublishAot) | PublishSingleFile = $(PublishSingleFile) | PublishReadyToRun = $(PublishReadyToRun)" Importance="High" />
  </Target>
</Project>