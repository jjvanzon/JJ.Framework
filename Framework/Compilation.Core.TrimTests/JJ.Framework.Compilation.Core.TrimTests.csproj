<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.6.$(BuildNum)</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <AutoTrimTest Condition="$(IsNCrunch)">False</AutoTrimTest>
    <AutoTrimTest Condition="!$(IsNCrunch)">True</AutoTrimTest>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Compilation.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Compilation.Core.Tests\obj\**" />
    <Compile Remove="..\Compilation.Core.Tests\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Compilation.Core\JJ.Framework.Compilation.Core.csproj" />
    <ProjectReference Include="..\Reflection.Core\JJ.Framework.Reflection.Core.csproj" />
    <ProjectReference Include="..\Testing.Core\JJ.Framework.Testing.Core.csproj" />
    <ProjectReference Include="..\Testing.Core.NCrunchless\JJ.Framework.Testing.Core.NCrunchless.csproj" />
    <ProjectReference Include="..\Testing.Core.MSTestless\JJ.Framework.Testing.Core.MSTestless.csproj" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
    <TrimmerRootAssembly Include="nCrunch.TestRuntime.DotNetCore" />
    <TrimmerRootAssembly Include="JJ.Framework.Compilation.Core.TrimTests" />
    <!-- Our using accessors sometimes makes trimmer cut out pieces of Common.Core leading to errors upon TrimTest run. -->
    <TrimmerRootAssembly Include="JJ.Framework.Common.Core" />
  </ItemGroup>

  <Import Project="..\PlatformCompatibility.Core.SharedProject\JJ.Framework.PlatformCompatibility.Core.SharedProject.projitems" Label="Shared" />
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>

