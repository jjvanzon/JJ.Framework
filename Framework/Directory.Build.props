<Project>
  
  <!-- BuildNum -->
  
  <PropertyGroup><BuildNum>0</BuildNum></PropertyGroup>
  <Import Project="BuildNum.xml" 
          Condition="'$(IsNCrunch)'!='True' And
                     !$(MSBuildProjectName.EndsWith('.Tests')) And
                     !$(MSBuildProjectName.Contains('.Tests.')) And
                     !$(MSBuildProjectName.Contains('Trimming.TestApp')) And
                     Exists('BuildNum.xml')" />

  <!-- Project Properties -->
  
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Description>A JJ.Framework Component</Description>
    <PackageTags>framework; architecture; utility</PackageTags>
    <Authors>JJ van Zon</Authors>
    <Copyright>Copyright © 2013 - 2026 Jan Joost van Zon</Copyright>
    <GenerateAssemblyInfo>True</GenerateAssemblyInfo>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>    
    <IncludeSymbols>True</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework</PackageProjectUrl>
    <PackageIcon>jj-icon-64x64-margin4.png</PackageIcon>
    <SuppressTfmSupportBuildWarnings>True</SuppressTfmSupportBuildWarnings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!-- Helper Variables -->

  <PropertyGroup>
    <IsCore>$(MSBuildProjectName.Contains('Core'))</IsCore>
    <IsLegacy>$(MSBuildProjectName.Contains('Legacy'))</IsLegacy>
    <IsNet48>$(MSBuildProjectName.Contains('Net48'))</IsNet48>
    <IsTest>False</IsTest>
    <IsTest Condition="$(MSBuildProjectName.EndsWith('.Tests'))">True</IsTest>
    <IsTest Condition="$(MSBuildProjectName.Contains('.Tests.'))">True</IsTest>
    <IsTrimTest>$(MSBuildProjectName.Contains('Trimming.TestApp'))</IsTrimTest>
    <IsNet5>$(TargetFramework.Equals('net5.0'))</IsNet5>
    <IsNet6>$(TargetFramework.Equals('net6.0'))</IsNet6>
    <IsNet7>$(TargetFramework.Equals('net7.0'))</IsNet7>
    <IsNet8>$(TargetFramework.Equals('net8.0'))</IsNet8>
    <IsNet9>$(TargetFramework.Equals('net9.0'))</IsNet9>
    <IsNet10>$(TargetFramework.Equals('net10.0'))</IsNet10>
    <IsOuterBuild>True</IsOuterBuild>
    <IsOuterBuild Condition="'$(TargetFramework)'!=''">False</IsOuterBuild>
    <IsInnerBuild>False</IsInnerBuild>
    <IsInnerBuild Condition="'$(TargetFramework)'!=''">True</IsInnerBuild>
  </PropertyGroup>

  <!-- Diagnostics (Build Type) -->
  <Target Name="JJ_Framework_Vars1" BeforeTargets="Build">
    <Message Text="$(MSBuildProjectName) > IsCore = $(IsCore) | IsLegacy = $(IsLegacy) | IsNet48 = $(IsNet48) | IsTest = $(IsTest) | IsTrimTest = $(IsTrimTest)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > IsOuterBuild = $(IsOuterBuild) | IsInnerBuild = $(IsInnerBuild)" Importance="High" />
    <Message Condition="'$(IsInnerBuild)'=='True'" Text="$(MSBuildProjectName) > IsNet5 = $(IsNet5) | IsNet6 = $(IsNet6) | IsNet7 = $(IsNet7) | IsNet8 = $(IsNet8) | IsNet9 = $(IsNet9) | IsNet10 = $(IsNet10)" Importance="High" />
  </Target>
  
  <!-- Packaging -->

  <PropertyGroup Condition="!$(IsTest) And !$(IsTrimTest)">
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>

  <!-- Strict for Core -->

  <PropertyGroup Condition="$(IsCore)">
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup Condition="$(IsCore) And !$(IsTest) And !$(IsTrimTest)">
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <WarningsAsErrors>$(WarningsAsErrors);CA1062</WarningsAsErrors> <!-- API surface nulls -->
  </PropertyGroup>

  <!-- Diagnostics -->
  <Target Name="JJ_Framework_Vars2" BeforeTargets="Build">
    <Message Text="$(MSBuildProjectName) > Nullable = $(Nullable) | GeneratePackageOnBuild = $(GeneratePackageOnBuild) | GenerateDocFile = $(GenerateDocumentationFile)" Importance="High" />
  </Target>

  <PropertyGroup>
    <SolutionDirjj>$(SolutionDir)</SolutionDirjj>
    <SolutionDirjj Condition="'$(SolutionDirjj)'==''">$(MSBuildThisFileDirectory)\..\</SolutionDirjj>
  </PropertyGroup>

  <!-- Icon -->

  <ItemGroup>
    <Content Include="$(SolutionDirjj)\Resources\jj-icon-64x64-margin4.png" Visible="False">
    <Pack>True</Pack>
      <PackagePath>\</PackagePath>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- README -->
  
  <PropertyGroup Condition="!Exists('$(MSBuildProjectDirectory)/README.MD')">
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup Condition="!Exists('$(MSBuildProjectDirectory)/README.MD')">
    <Content Include="$(SolutionDirjj)\README.md" Visible="False">
      <Pack>True</Pack>
      <PackagePath>\README.md</PackagePath>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)/README.MD')">
    <PackageReadmeFile>README.MD</PackageReadmeFile>
  </PropertyGroup>       

  <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)/README.MD')">
    <Content Include="README.MD">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Publish -->

  <PropertyGroup Condition="$(IsTrimTest)">
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>True</SelfContained>
    <PublishReadyToRun>True</PublishReadyToRun>
  </PropertyGroup>
  
  <PropertyGroup Condition="$(IsTrimTest) And ($(IsNet9) Or $(IsNet10))">
    <PublishTrimmed>True</PublishTrimmed>
    <PublishAot>True</PublishAot>
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsTrimTest) And $(IsNet8)">
    <PublishTrimmed>True</PublishTrimmed>
    <PublishAot>True</PublishAot>
    <!--<PublishSingleFile>True</PublishSingleFile>-->
  </PropertyGroup>

  <PropertyGroup Condition="$(IsTrimTest) And ($(IsNet6) Or $(IsNet7))">
    <PublishTrimmed>True</PublishTrimmed>
    <!--<PublishAot>True</PublishAot>-->
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsTrimTest) And $(IsNet5)">
    <!--<PublishTrimmed>True</PublishTrimmed>-->
    <!--<PublishAot>True</PublishAot>-->
    <PublishSingleFile>True</PublishSingleFile>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsTrimTest) And '$(Configuration)'=='Release'">
    <CopyOutputSymbolsToPublishDirectory>False</CopyOutputSymbolsToPublishDirectory>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsTrimTest) And $(IsInnerBuild)">
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PublishDir>bin\$(Configuration)\$(TargetFramework)\publish\$(RuntimeIdentifier)</PublishDir>
  </PropertyGroup>

  <Target Name="PublishAfterBuild" AfterTargets="Build" Condition="$(IsTrimTest) And $(IsInnerBuild)">

    <MSBuild Condition="'$(IsNCrunch)'!='True'" Targets="Publish" 
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true" />

    <MSBuild Condition="'$(IsNCrunch)'=='True' And ($(IsNet9) Or $(IsNet10))" Targets="Publish"
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishTrimmed=true;PublishAot=true;PublishSingleFile=true;PublishReadyToRun=true">
    </MSBuild>

    <MSBuild Condition="'$(IsNCrunch)'=='True' And $(IsNet8)" Targets="Publish"
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishTrimmed=true;PublishAot=true;PublishReadyToRun=true">
    </MSBuild>

    <!--<MSBuild Condition="'$(IsNCrunch)'=='True' And ($(IsNet6) Or $(IsNet7))" Targets="Publish" 
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishTrimmed=true;PublishSingleFile=true;PublishReadyToRun=true" />

    <MSBuild Condition="'$(IsNCrunch)'=='True' And $(IsNet5)" Targets="Publish" 
             Projects="$(MSBuildProjectFile)" Properties="NoBuild=true;RuntimeIdentifier=win-x64;SelfContained=true;PublishSingleFile=true;PublishReadyToRun=false" />-->
  </Target>
  
  <Target Name="RemoveSymbolsAndDocs" AfterTargets="Publish" Condition="$(IsTrimTest) And $(Configuration)=='Release' And '$(PublishDir)'!=''">
    <Message Importance="High" Text="Removing symbols and docs from publish directory..." />
    <Message Importance="High" Text="PublishDir = $(PublishDir)" />

    <ItemGroup><PdbsToDeletejj Include="$(PublishDir)*.pdb" /></ItemGroup>
    <Message Importance="High" Text="Removing $(PublishDir)*.pdb" />
    <Message Importance="High" Text="Removing @(PdbsToDeletejj)" />
    <Delete Files="@(PdbsToDeletejj)" />

    <ItemGroup><XmlsToDeletejj Include="$(PublishDir)*.xml" /></ItemGroup>
    <Message Importance="High" Text="Removing $(PublishDir)*.xml" />
    <Message Importance="High" Text="Removing @(XmlsToDeletejj)" />
    <Delete Files="@(XmlsToDeletejj)" />
  </Target>

  <!-- Diagnostics (Publish) -->
  <Target Name="JJ_Framework_Vars3" AfterTargets="Build" Condition="$(IsTrimTest) And $(IsInnerBuild)">
    <Message Text="$(MSBuildProjectName) > SelfContained = $(SelfContained) | PublishTrimmed = $(PublishTrimmed) | PublishAot = $(PublishAot) | PublishSingleFile = $(PublishSingleFile) | PublishReadyToRun = $(PublishReadyToRun)" Importance="High" />
  </Target>

  <!-- Trim Test -->

  <Target Name="RunTrimTest" AfterTargets="PublishAfterBuild"
          Condition="$(IsTrimTest) And $(IsInnerBuild) And '$(PublishDir)'!='' And
                   ('$(IsNCrunch)'=='True' Or '$(Configuration)'=='Release')">

    <!-- Helper Vars -->
    <PropertyGroup>
      <TrimmedExe>$(PublishDir)\$(MSBuildProjectName).exe</TrimmedExe>
      <TrimRunOutputFilePath>$(PublishDir)$(MSBuildProjectName)-Output.txt</TrimRunOutputFilePath>
    </PropertyGroup>

    <!-- Run Exe -->
    <Exec Command="&quot;$(TrimmedExe)&quot; &gt; &quot;$(TrimRunOutputFilePath)&quot; 2&gt;&amp;1"
          IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="TrimRunExitCode" />
    </Exec>

    <!-- Helper Vars -->
    <PropertyGroup>
      <TrimRunHasError>False</TrimRunHasError>
      <TrimRunHasError Condition="'$(TrimRunExitCode)'!='' And '$(TrimRunExitCode)'!='0'">True</TrimRunHasError>
    </PropertyGroup>

    <!-- Read output -->
    <ReadLinesFromFile File="$(TrimRunOutputFilePath)">
      <Output TaskParameter="Lines" ItemName="TrimRunOutputLines" />
    </ReadLinesFromFile>

    <!-- Parse -->
    <PropertyGroup>
      <!-- Join output -->
      <TrimRunOutputJoined>@(TrimRunOutputLines, '&#x0D;&#x0A;')</TrimRunOutputJoined>
      <!-- Extract text after 'Exception: ' -->
      <TrimRunException>$([System.Text.RegularExpressions.Regex]::Match('$(TrimRunOutputJoined)','(?s)Exception:\s*(.*)').Groups[1].Value)</TrimRunException>
      <!-- Build error text -->
      <TrimRunErrorText>$(TrimRunException)</TrimRunErrorText>
      <!-- Fallback to complete exe output -->
      <TrimRunErrorText Condition="'$(TrimRunException)'==''">$(TrimRunOutputJoined)</TrimRunErrorText>
      <TrimRunErrorText>$(MSBuildProjectName) > Exit Code $(TrimRunExitCode). $(TrimRunErrorText)</TrimRunErrorText>
    </PropertyGroup>

    <!-- Diagnostics (Trim Test) -->
    <PropertyGroup>
      <TrimmedExeExists>False</TrimmedExeExists>
      <TrimmedExeExists Condition="Exists('$(TrimmedExe)')">True</TrimmedExeExists>
      <TrimRunOutputExists>False</TrimRunOutputExists>
      <TrimRunOutputExists Condition="Exists('$(TrimRunOutputFilePath)')">True</TrimRunOutputExists>
    </PropertyGroup>
    <Message Text="$(MSBuildProjectName) > TrimmedExe Exists = $(TrimmedExeExists) | $(TrimmedExe)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > Output Exists = $(TrimRunOutputExists) | $(TrimRunOutputFilePath)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > ExitCode = $(TrimRunExitCode)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > HasError = $(TrimRunHasError)" Importance="High" />
    <Message Text="$(MSBuildProjectName) > Exception = $(TrimRunException)" Importance="High" />
    <!--<Message Text="$(MSBuildProjectName) > EXCEPTION TEXT NOT EXTRACTED!" Condition="$(TrimRunHasError) And '$(TrimRunException)'==''" Importance="High" />-->
    <!--<Message Text="$(MSBuildProjectName) > OutputJoined = $(TrimRunOutputJoined)" Importance="High" />-->

    <!-- Failure => Error List -->
    <Error Condition="$(TrimRunHasError)" Text="$(TrimRunErrorText)" />

    <!-- Build Output -->
    <Message Text="$(TrimRunOutputJoined)" Importance="High" />
  </Target>

  <!-- Establish Determinism (green check in NuGet Package Explorer page) -->
  <PropertyGroup Condition="'$(TF_BUILD)'=='true'">
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- Warnings Disabled Globally -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);NU1701</NoWarn> <!--Package was not restored with project target framework.-->
    <NoWarn>$(NoWarn);CS8632</NoWarn> <!--Nullable annotation used without nullable option on.-->
    <NoWarn>$(NoWarn);CS1573</NoWarn> <!--Parameter 'parameter' has no matching param tag in the XML comment for 'parameter' (but other parameters do)-->
    <NoWarn>$(NoWarn);CA1510</NoWarn> <!--Use ThrowIfNull-->
    <NoWarn>$(NoWarn);CS0078</NoWarn> <!--The 'l' suffix is easily confused with the digit '1'-->
    <NoWarn>$(NoWarn);NETSDK1138</NoWarn> <!--The target framework 'net7.0' is out of support-->
    <NoWarn>$(NoWarn);NU1510</NoWarn> <!--PackageReference will not be pruned-->
    <!-- See also: Directory.Build.targets for more disabled warnings. -->
  </PropertyGroup>

  <!-- Warnings Disabled for Tests -->
  <PropertyGroup Condition="$(IsTest) Or $(IsTrimTest)">
    <NoWarn>$(NoWarn);CS0219</NoWarn> <!--Unused local variable-->
    <NoWarn>$(NoWarn);CS0414</NoWarn> <!--Field is assigned but its value is never used-->
    <NoWarn>$(NoWarn);IDE0060</NoWarn> <!--Unused parameter-->
    <NoWarn>$(NoWarn);IDE0004</NoWarn> <!--Unnecessary cast-->
    <NoWarn>$(NoWarn);IDE0051</NoWarn> <!--Unused private members-->
    <NoWarn>$(NoWarn);CS0067</NoWarn> <!--Event never invoked-->
    <NoWarn>$(NoWarn);CS0649</NoWarn> <!--Field never assigned-->
    <NoWarn>$(NoWarn);IDE0032</NoWarn> <!--Use auto-property-->
    <NoWarn>$(NoWarn);CA2263</NoWarn> <!--Prefer type arg-->
    <NoWarn>$(NoWarn);CS0169</NoWarn> <!--Field is never used-->
    <NoWarn>$(NoWarn);CS0162</NoWarn> <!--Unreachable code-->
    <!--<NoWarn>$(NoWarn);IDE0044</NoWarn>--><!--Field can be readonly-->
  </PropertyGroup>

  <!-- Warnings Disabled for Doc-Only Members. -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);CS1711</NoWarn> <!--surplus typeparam tag-->
    <NoWarn>$(NoWarn);CS1572</NoWarn> <!--surplus param tag-->
    <NoWarn>$(NoWarn);CS1734</NoWarn> <!--paramref tag without parameter-->
  </PropertyGroup>
  
  <!-- Warnings Disabled for Legacy Code -->
  <PropertyGroup Condition="$(IsLegacy)">
    <NoWarn>$(NoWarn);IDE0063</NoWarn> <!--Use simple 'using' statement-->
    <NoWarn>$(NoWarn);IDE0034</NoWarn> <!--Simplify 'default' expression-->
    <NoWarn>$(NoWarn);IDE0057</NoWarn> <!--Use range operator-->
    <NoWarn>$(NoWarn);IDE0044</NoWarn> <!--Field read-only-->
    <NoWarn>$(NoWarn);IDE0002</NoWarn> <!--Redundant static qualifier-->
    <NoWarn>$(NoWarn);IDE0051</NoWarn> <!--Type member never used-->
  </PropertyGroup>

</Project>