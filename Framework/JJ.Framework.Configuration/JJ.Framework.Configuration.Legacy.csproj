<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.254.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;netstandard2.1;netstandard2.0</TargetFrameworks>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;netstandard2.1;netstandard2.0</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsNet8) Or $(IsNet9) Or $(IsNet10)">
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="$(IsNet6) Or $(IsNet7)">
    <IsTrimmable>True</IsTrimmable>
  </PropertyGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Common\JJ.Framework.Common.Legacy.csproj" />
    <ProjectReference Include="..\JJ.Framework.Reflection\JJ.Framework.Reflection.Legacy.csproj" />
    <ProjectReference Include="..\JJ.Framework.Xml\JJ.Framework.Xml.Legacy.csproj" />
  </ItemGroup>
  
  <ItemGroup>
    <!-- PrivateAssets="all" prevents leakage upstream
         conflicting with classic System.Configuration (.NET Framework / pre-.NET5 builds). -->
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.3" 
                      PrivateAssets="all" />
  </ItemGroup>
  
  <Import Project="..\PlatformCompatibility.Core.SharedProject\JJ.Framework.PlatformCompatibility.Core.SharedProject.projitems" Label="Shared" />
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>
