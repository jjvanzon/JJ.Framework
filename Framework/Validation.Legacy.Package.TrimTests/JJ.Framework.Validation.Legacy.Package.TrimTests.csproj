<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.259.0</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Validation.Legacy.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Validation.Legacy.Tests\obj\**" />
    <Compile Remove="..\Validation.Legacy.Tests\bin\**" />
    <Compile Include="..\Validation.Legacy.TrimTests\Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Testing.Core.NCrunchless" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.259.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7347" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Validation.Legacy.Package.Tests.Helpers\JJ.Framework.Validation.Legacy.Package.Tests.Helpers.csproj" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7347" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>
</Project>
