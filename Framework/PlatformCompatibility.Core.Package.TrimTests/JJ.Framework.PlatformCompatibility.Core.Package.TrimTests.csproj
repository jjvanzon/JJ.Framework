<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.4.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.4.5864" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.1.5697" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.251.5697" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\PlatformCompatibility.Core.TestBase\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\PlatformCompatibility.Core.TestBase\obj\**" />
    <Compile Remove="..\PlatformCompatibility.Core.TestBase\bin\**" />
    <Compile Include="..\PlatformCompatibility.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\PlatformCompatibility.Core.Tests\obj\**" />
    <Compile Remove="..\PlatformCompatibility.Core.Tests\bin\**" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.4.5992" />
  </ItemGroup>
</Project>
