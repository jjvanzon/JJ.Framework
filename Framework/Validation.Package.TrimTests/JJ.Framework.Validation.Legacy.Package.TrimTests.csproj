<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.252.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Validation.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Validation.Tests\obj\**" />
    <Compile Remove="..\Validation.Tests\bin\**" />
    <Compile Include="..\Validation.TrimTests\Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Testing.Core.NCrunchless" Version="4.1.5698" />
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.252.6001" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.1.5697" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.4.6001" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Validation.Package.Tests.Helpers\JJ.Framework.Validation.Legacy.Package.Tests.Helpers.csproj" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.4.5992" />
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>
</Project>
