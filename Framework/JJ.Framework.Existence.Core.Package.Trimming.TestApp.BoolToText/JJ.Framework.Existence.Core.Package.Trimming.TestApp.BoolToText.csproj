<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.4.$(BuildNum)</Version>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="4.1.5729" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.1.5697" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.251.5697" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.4.5864" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Existence.Core.Tests.BoolToText\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Existence.Core.Tests.BoolToText\obj\**" />
    <Compile Remove="..\JJ.Framework.Existence.Core.Tests.BoolToText\bin\**" />
    <Compile Include="..\JJ.Framework.Existence.Core.Trimming.TestApp.BoolToText\Program.cs" />
    <Compile Include="..\JJ.Framework.Existence.Core.Trimming.TestApp.BoolToText\UsingMore.cs" />
  </ItemGroup>

  <Import Project="..\JJ.Framework.SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

