<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.259.$(BuildNum)</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Text.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Text.Core.Tests\obj\**" />
    <Compile Remove="..\Text.Core.Tests\bin\**" />
    <Compile Include="..\Text.Core.TrimTests\Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Text.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core.NCrunchless" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7347" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>
</Project>
