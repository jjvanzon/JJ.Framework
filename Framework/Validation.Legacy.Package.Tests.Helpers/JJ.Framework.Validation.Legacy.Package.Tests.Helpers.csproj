<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks> <!-- NCrunch wide range for Package.Tests -->
    <RootNamespace>JJ.Framework.Validation.Legacy.Tests.Helpers</RootNamespace>
    <Version>0.259.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Validation.Legacy.Tests.Helpers\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Validation.Legacy.Tests.Helpers\**\*.resx" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Validation.Legacy.Tests.Helpers\obj\**" />
    <Compile Remove="..\Validation.Legacy.Tests.Helpers\bin\**" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7246" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.259.7246" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

