<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.251.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Validation.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Validation.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Validation.Tests\bin\**" />
    <Compile Include="..\JJ.Framework.Validation.Trimming.TestApp\Program.cs" />
    <Compile Include="..\JJ.Framework.Validation.Trimming.TestApp\UsingMore.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Testing.Core.NCrunchless" Version="4.1.5698" />
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.251.5705" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.1.5697" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Validation.Package.Tests.Helpers\JJ.Framework.Validation.Legacy.Package.Tests.Helpers.csproj" />
  </ItemGroup>

  <Import Project="..\JJ.Framework.PlatformCompatibility.Core\JJ.Framework.PlatformCompatibility.Core.projitems" Label="Shared" />
  <Import Project="..\JJ.Framework.SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

</Project>
