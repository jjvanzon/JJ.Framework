<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.259.0</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks> <!-- NCrunch Package TrimTests -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Reflection.Legacy" Version="0.259.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7347" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Reflection.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Reflection.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Reflection.Tests\bin\**" />
    <Compile Include="..\Reflection.Legacy.TrimTests\Program.cs" />
    <Compile Include="..\Reflection.Legacy.TrimTests\Untrimmer.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reflection.Core.Tests.Helpers\JJ.Framework.Reflection.Core.Tests.Helpers.csproj" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.1.7347" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

</Project>

