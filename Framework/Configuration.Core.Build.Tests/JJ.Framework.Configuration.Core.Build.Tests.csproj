<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net5.0;net461</TargetFrameworks>
    <Version>4.6.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Configuration.Core\JJ.Framework.Configuration.Core.csproj" />
    <ProjectReference Include="..\JJ.Framework.Configuration\JJ.Framework.Configuration.Legacy.csproj" />
    <ProjectReference Include="..\Testing.Core\JJ.Framework.Testing.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="app.config">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  
 <ItemGroup>
    <EmbeddedResource Include="..\Configuration.Core.Tests\JJ.Framework.Configuration.Core.Tests.csproj" Link="TestResources\JJ.Framework.Configuration.Core.Tests.csproj" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\JJ.Framework.Configuration.Core.Tests.dll.config" Link="TestResources\JJ.Framework.Configuration.Core.Tests.dll.config" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\app.config" Link="TestResources\app.config" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\web.config" Link="TestResources\web.config" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\testhost.dll.config" Link="TestResources\testhost.dll.config" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\nCrunch.TaskRunner.DotNetCore.20.x64.dll.config" Link="TestResources\nCrunch.TaskRunner.DotNetCore.20.x64.dll.config" />
    <EmbeddedResource Include="..\Configuration.Core.Tests\*.cs" Link="TestResources\%(Filename)%(Extension)" />
  </ItemGroup>

  <Import Project="..\PlatformCompatibility.Core.SharedProject\JJ.Framework.PlatformCompatibility.Core.SharedProject.projitems" Label="Shared" />
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <!-- Simulate what NuGet consumers get automatically via the build/ convention. -->
  <Import Project="..\Configuration.Core\build\JJ.Framework.Configuration.Core.targets" />
</Project>
