<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>5.2.$(BuildNum)-preview</Version>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;netstandard2.1;netstandard2.0</TargetFrameworks> <!-- NCrunch Libs 3 TFMs -->
    <Description>Use C# to call the dotnet.exe CLI at runtime to kick off compilations of .NET projects.</Description>
    <PackageTags>dotnet exe cli thin wrapper process start msbuild utility testing error exit code command line commandline cmd build rebuild msrebuild install package nuget restore result args diagnostics options buildconfiguration buildconf parallel timeout verbosity logging binlog output assert assertion exitcode stdout stderr quiet minimal normal detailed diagnostic defaults</PackageTags>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.Compilation.Core</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.Compilation.Core</PackageProjectUrl>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsNet8) Or $(IsNet9) Or $(IsNet10)">
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="$(IsNet6) Or $(IsNet7)">
    <IsTrimmable>True</IsTrimmable>
  </PropertyGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\Existence.Core\JJ.Framework.Existence.Core.csproj" />
  </ItemGroup>

  <Import Project="..\PlatformCompatibility.Core.SharedProject\JJ.Framework.PlatformCompatibility.Core.SharedProject.projitems" Label="Shared" />
  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
</Project>