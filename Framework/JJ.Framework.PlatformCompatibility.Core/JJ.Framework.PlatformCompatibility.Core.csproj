<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.1.$(BuildNum)</Version>
    <TargetFramework>netstandard2.0</TargetFramework>
    <!--<PackageId>JJ.Framework.PlatformCompatibility.Core</PackageId>-->
    <Description>
      Shims that mimic new features for old .NET versions, so new code can compile for older tech. 
      Internal support for JJ projects.
    </Description>
    <PackageTags>tfm shim compatibility shims</PackageTags>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.PlatformCompatibility.Core</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.PlatformCompatibility.Core</PackageProjectUrl>
    <!--
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoDefaultCompileItems>true</NoDefaultCompileItems>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <IncludeSymbols>false</IncludeSymbols>
    -->
  </PropertyGroup>

  <ItemGroup>
    <None Include="buildTransitive\JJ.Framework.PlatformCompatibility.Core.targets" Pack="true" PackagePath="buildTransitive\JJ.Framework.PlatformCompatibility.Core.targets" />
    <None Include="*.cs" Pack="true" PackagePath="buildTransitive\JJ.Framework.PlatformCompatibility.Core\" />
  </ItemGroup>
</Project>
