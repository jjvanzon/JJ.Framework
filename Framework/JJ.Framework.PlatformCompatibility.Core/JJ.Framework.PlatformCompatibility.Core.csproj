<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.1.$(BuildNum)</Version>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Description>Internal support for JJ projects. Shims that mimic new features for old .NETs, so new code can compile for older tech.</Description>
    <PackageTags>stub shim platform stubs compatibility shims tfm</PackageTags>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.PlatformCompatibility.Core</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/JJ.Framework.PlatformCompatibility.Core</PackageProjectUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="buildTransitive\JJ.Framework.PlatformCompatibility.Core.targets" Pack="true" PackagePath="buildTransitive\JJ.Framework.PlatformCompatibility.Core.targets" />
    <None Include="*.cs" Pack="true" PackagePath="buildTransitive\JJ.Framework.PlatformCompatibility.Core\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Build\JJ.Framework.Build.csproj" />
  </ItemGroup>
</Project>
