<Project>
  <Import Project="$(MSBuildThisFileDirectory)\Vars.xml" Condition="'$(VarsLoaded)'!='True'" />
  
  <!--<PropertyGroup Condition="'$(IsNCrunch)'=='True' And $(IsOuterBuild) And !$(IsNet48)">-->
 <PropertyGroup>
    <TargetFrameworks Condition="!$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;netstandard2.1;netstandard2.0</TargetFrameworks>
    <!-- Tame NCrunch -->
    <TargetFrameworks Condition="$(IsNCrunch) And !$(IsTest) And !$(IsTrimTest)">net10.0;netstandard2.1;netstandard2.0</TargetFrameworks>
    <TargetFrameworks Condition="$(IsNCrunch) And $(IsTest)">net10.0;net461</TargetFrameworks>
    <TargetFrameworks Condition="$(IsNCrunch) And $(IsTrimTest)">net10.0;net5.0</TargetFrameworks>
  </PropertyGroup>
</Project>
