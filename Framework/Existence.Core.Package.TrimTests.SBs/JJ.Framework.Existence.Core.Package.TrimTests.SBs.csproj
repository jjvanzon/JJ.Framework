<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.5.$(BuildNum)</Version>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="4.5.6073" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.5.6068" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.253.6068" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.5.6073" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Existence.Core.Tests.SBs\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Existence.Core.Tests.SBs\obj\**" />
    <Compile Remove="..\Existence.Core.Tests.SBs\bin\**" />
    <Compile Include="..\Existence.Core.TrimTests.SBs\Program.cs" />
    <Compile Remove="..\Existence.Core.Package.TrimTests.SBs\Using.cs" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />
  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="4.5.6068" />
  </ItemGroup>
</Project>

