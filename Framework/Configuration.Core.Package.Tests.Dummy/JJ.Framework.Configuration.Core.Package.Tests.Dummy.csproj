<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks> <!-- Can't reach Directory.Build.props in run-time compilations. -->
    <Version>5.2.0</Version>
    <GenerateDocumentationFile>False</GenerateDocumentationFile>
    <LangVersion>latest</LangVersion>
    <SuppressTfmSupportBuildWarnings>True</SuppressTfmSupportBuildWarnings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Configuration.Core.Tests.Dummy\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Configuration.Core.Tests.Dummy\obj\**" />
    <Compile Remove="..\Configuration.Core.Tests.Dummy\bin\**" />
    <None Include="..\Configuration.Core.Tests.Dummy\**\*.config" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <None Remove="..\Configuration.Core.Tests.Dummy\obj\**\*.config" />
    <None Remove="..\Configuration.Core.Tests.Dummy\bin\**\*.config" />
    <None Remove="..\Configuration.Core.Tests.Dummy\app.config" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.Configuration.Core" Version="5.1.7388" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)'!='net461'">
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.3" />
  </ItemGroup>
</Project>