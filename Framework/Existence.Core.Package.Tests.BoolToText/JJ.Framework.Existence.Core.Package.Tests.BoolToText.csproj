<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.5.$(BuildNum)</Version>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="4.4.6001" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.5.6066" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.251.5697" />
    <PackageReference Include="MSTest" Version="3.7.3" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.4.6001" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Existence.Core.Tests.BoolToText\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Existence.Core.Tests.BoolToText\obj\**" />
    <Compile Remove="..\Existence.Core.Tests.BoolToText\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

