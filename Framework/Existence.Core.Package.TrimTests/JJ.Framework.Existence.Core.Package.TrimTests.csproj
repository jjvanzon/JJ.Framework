<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>5.1.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Existence.Core" Version="5.0.7235" />
    <PackageReference Include="JJ.Framework.Existence.Core.Tests.Helpers" Version="3.7.4872" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.0.7235" />
    <PackageReference Include="JJ.Framework.Testing.Legacy" Version="0.258.7235" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.0.7235" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Existence.Core.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Existence.Core.Tests\obj\**" />
    <Compile Remove="..\Existence.Core.Tests\bin\**" />
    <Compile Include="..\Existence.Core.TrimTests\Program.cs" />
    <!-- Exclude tests that rely heavily on reflection or APIs not compatible with trimming analysis -->
    <Compile Remove="..\Existence.Core.Tests\Existence_CrossRefCollectionTypes_Tests.cs" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
    <PackageReference Include="JJ.Framework.Testing.Core.MSTestless" Version="5.0.7235" />
  </ItemGroup>
</Project>

