<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.252.$(BuildNum)</Version>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\JJ.Framework.Business.Tests\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\JJ.Framework.Business.Tests\obj\**" />
    <Compile Remove="..\JJ.Framework.Business.Tests\bin\**" />
    <Compile Include="..\JJ.Framework.Business.Trimming.TestApp\Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Business.Legacy" Version="0.251.5729" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="4.1.5697" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.4.5864" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <TrimmerRootDescriptor Include="Linker.xml" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\JJ.Framework.Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

