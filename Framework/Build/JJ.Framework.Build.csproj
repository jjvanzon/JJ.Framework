<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>4.6.$(BuildNum)</Version>
    <TargetFrameworks>netstandard2.0</TargetFrameworks>
    <Description>Internal infrastructure. Triggers initialization at the start of building JJ.Framework.</Description>
    <RepositoryUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/Build</RepositoryUrl>
    <PackageProjectUrl>https://github.com/jjvanzon/JJ.Framework/tree/main/Framework/Build</PackageProjectUrl>
  </PropertyGroup>

  <PropertyGroup Condition="$(IsNet8) Or $(IsNet9) Or $(IsNet10)">
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>
  <PropertyGroup Condition="$(IsNet6) Or $(IsNet7)">
    <IsTrimmable>True</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JJ.AutoIncrementVersion" Version="4.7.6252">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
</Project>
