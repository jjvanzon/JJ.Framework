<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net461</TargetFrameworks>
    <RootNamespace>JJ.Framework.Validation.Legacy.Tests.Helpers</RootNamespace>
    <Version>0.253.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Validation.Tests.Helpers\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\Validation.Tests.Helpers\**\*.resx" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\Validation.Tests.Helpers\obj\**" />
    <Compile Remove="..\Validation.Tests.Helpers\bin\**" />
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="4.5.6073" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.Validation.Legacy" Version="0.253.6073" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>

