<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0</TargetFrameworks>
    <Version>4.6.$(BuildNum)</Version>
    <!-- Produce an assembly with the exact name expected by the runtime -->
    <AssemblyName>nCrunch.TestRuntime.DotNetCore</AssemblyName>
    <PackageId>JJ.Framework.Testing.Core.NCrunchless</PackageId>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);CS1591</NoWarn> <!--Missing doc lenience-->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" />
  </ItemGroup>

</Project>
