<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks Condition="$(IsNCrunch)">net10.0;net9.0;net8.0;net7.0;net6.0;net5.0;net48;net462;net461</TargetFrameworks> <!-- NCrunch wide range for PlatformCompatibility -->
    <Version>5.1.$(BuildNum)</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\PlatformCompatibility.Core.TestBase\**\*.cs" Link="%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Remove="..\PlatformCompatibility.Core.TestBase\obj\**" />
    <Compile Remove="..\PlatformCompatibility.Core.TestBase\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JJ.Framework.PlatformCompatibility.Core" Version="5.1.7347" />
    <PackageReference Include="JJ.Framework.Testing.Core" Version="5.1.7347" />
  </ItemGroup>

  <Import Project="..\SharedProject.Core\JJ.Framework.SharedProject.Core.projitems" Label="Shared" />

  <ItemGroup>
    <ProjectReference Include="..\Build\JJ.Framework.Build.csproj" TreatAsUsed="True" />
  </ItemGroup>
</Project>
